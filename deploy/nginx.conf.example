# Example nginx config for Telegram Durak Game.
# Telegram WebApp REQUIRES HTTPS — terminate TLS here (e.g. with Let's Encrypt).
#
# /opt/durak/static    — static frontend (index.html)
# 127.0.0.1:8765       — FastAPI backend (uvicorn)

server {
    listen 80;
    server_name example.com;
    return 301 https://$host$request_uri;
}

server {
    listen 443 ssl http2;
    server_name example.com;

    ssl_certificate     /etc/letsencrypt/live/example.com/fullchain.pem;
    ssl_certificate_key /etc/letsencrypt/live/example.com/privkey.pem;

    # ── Durak REST API ────────────────────────────────────────────────────
    location /api/ {
        proxy_pass http://127.0.0.1:8765;
        proxy_set_header Host $host;
        proxy_set_header X-Real-IP $remote_addr;
        proxy_set_header X-Forwarded-For $proxy_add_x_forwarded_for;
        proxy_set_header X-Forwarded-Proto $scheme;
    }

    # ── Durak WebSocket ───────────────────────────────────────────────────
    location /durak-ws/ {
        proxy_pass http://127.0.0.1:8765;
        proxy_http_version 1.1;
        proxy_set_header Upgrade $http_upgrade;
        proxy_set_header Connection "upgrade";
        proxy_set_header Host $host;
        proxy_read_timeout 3600;
    }

    # ── Durak static frontend ─────────────────────────────────────────────
    location /durak {
        alias /opt/durak/static;
        index index.html;
        try_files $uri $uri/ /durak/index.html;
        gzip on;
        gzip_types text/html text/css application/javascript;
        add_header Cache-Control "public, max-age=60";
    }
}
